<%- include("partials/head") %>
<%- include("partials/header") %>

<h2>Jobs List</h2>

<% if (jobs && jobs.length) { %>

  <table id="jobs-table">
    <tr id="jobs-table-header">
      <th>Company</th>
      <th>Position</th>
      <th>Status</th>
      <th colspan="2"></th>
    </tr>
  
    <% jobs.forEach(job => { %>
      <tr>
        <td><%= job.companyName %></td>
        <td><%= job.positionName %></td>
        <td><%= job.status %></td>

        <td>
          <a href="/jobs/edit/<%= job._id %>">
            <button type="button">Edit</button>
          </a>
        </td>

        <td>
          <form action="/jobs/delete/<%= job._id %>" method="POST" style="display:inline">
            <input type="hidden" name="_csrf" value="<%= _csrf %>">
            <button type="submit">Delete</button>
          </form>
        </td>

      </tr>
    <% }) %>

  <% } else { %>
    <tr>
      <td colspan="5">No jobs added yet.</td>
    </tr>
  <% } %>
</table>

<a href="/jobs/new">
  <button type="button">Add a new job</button>
</a>

<%- include("partials/footer") %>